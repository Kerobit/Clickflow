{
  "name": "@kerobit/clickflow-core",
  "version": "0.1.0",
  "description": "ClickFlow Core: High-performance SQL-first ClickHouse client with typed schemas, migrations, and ingest buffers.",
  "license": "MPL-2.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "peerDependencies": {
    "@clickhouse/client": ">=1.0.0"
  },
  "devDependencies": {
    "@clickhouse/client": "^1.18.2",
    "@types/lodash-es": "^4.17.12",
    "@vitest/coverage-v8": "^2.1.9",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "kysely": "^0.28.0",
    "lodash-es": "^4.18.1",
    "zod": "^4.3.6"
  }
}
