{
  "name": "@clickflow/core",
  "version": "0.1.0",
  "description": "ClickHouse OLAP client for TypeScript: SQL-first, typed helpers, ingest buffers, migrations",
  "license": "MPL-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "peerDependencies": {
    "@clickhouse/client": ">=1.0.0"
  },
  "devDependencies": {
    "@clickhouse/client": "^1.18.2",
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
